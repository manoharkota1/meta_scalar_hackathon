# Required for inference.py
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
HF_TOKEN=hf_your_token_here

# Optional (used only if your inference flow uses from_docker_image)
LOCAL_IMAGE_NAME=code-review-triage-env:latest

# Optional runtime tuning
BENCHMARK=code_review_triage_env
MAX_STEPS=24
SUCCESS_SCORE_THRESHOLD=0.75
